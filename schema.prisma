generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Category {
  id          Int       @id(map: "Categories_pkey") @default(autoincrement())
  name        String?
  icon        String?
  createdAt   DateTime? @db.Timestamptz(6)
  updatedAt   DateTime? @updatedAt @db.Timestamptz(6)
  description String?
  hidden      Boolean   @default(false)
}

model Builder {
  id   Int     @id(map: "Builders_pkey") @default(autoincrement())
  name String?
}

model Transaction {
  amount               Float
  date                 DateTime  @db.Timestamptz(6)
  notes                String?
  description          String?
  tags                 String[]
  categoryId           Int
  builderId            Int?
  id                   Int       @id(map: "Transactions_pkey") @default(autoincrement())
  createdAt            DateTime? @db.Timestamptz(6)
  updatedAt            DateTime? @updatedAt @db.Timestamptz(6)
  relatedTransactionId Int?
}

model Budget {
  id         Int   @id @default(autoincrement())
  amount     Float @default(0)
  categoryId Int
}

model Tool {
  id            Int       @id @default(autoincrement())
  name          String?
  link          String?
  aquired       Boolean   @default(false)
  createdAt     DateTime? @db.Timestamptz(6)
  updatedAt     DateTime? @updatedAt @db.Timestamptz(6)
  transactionId Int?
}

model WorkHour {
  id    Int       @id @default(autoincrement())
  hours Float     @default(0)
  date  DateTime? @unique @db.Timestamptz(6)
}

model Task {
  id                  Int       @id @default(autoincrement())
  name                String
  isCompleted         Boolean   @default(false)
  completionDate      DateTime? @db.Timestamptz(6)
  createdAt           DateTime? @db.Timestamptz(6)
  updatedAt           DateTime? @updatedAt @db.Timestamptz(6)
  taskSectionId       Int?
  parts               Int[]
  manualPageReference String?
  tools               Int[]
}

model TaskSection {
  id          Int     @id(map: "TaskCategory_pkey") @default(autoincrement())
  name        String
  description String?
  position    Int[]
}

model Milestone {
  id               Int      @id @default(autoincrement())
  title            String
  date             DateTime @db.Timestamptz(6)
  description      String
  featuredImage    String?
  additionalImages String[]
  createdAt        DateTime @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @db.Timestamptz(6)
}

model PartsInventory {
  id                   Int       @id(map: "partsinventory_pkey") @default(autoincrement())
  part                 String
  quantity             Int
  quantityReceived     Int       @default(0)
  status               String    @default("Not Received")
  section              String
  category             String
  notes                String?
  estimatedInstallTime String?
  installDifficulty    String?
  manualPageReference  String?
  isOptional           Boolean   @default(false)
  installDate          DateTime? @db.Timestamptz(6)
  createdAt            DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  dependencies         Int[]
  inspectionNotes      String?
  image                String?
}

model InventoryBox {
    id              Int               @id @default(autoincrement())
    boxNumber       String            @unique
    description     String?
    categories      InventoryCategory[]
    
    // Timestamps
    createdAt       DateTime          @default(now())
    updatedAt       DateTime          @updatedAt
}

model InventoryCategory {
    id              Int               @id @default(autoincrement())
    categoryNumber  String
    categoryName    String
    parts           InventoryPart[]
    box             InventoryBox      @relation(fields: [boxId], references: [id], onDelete: Cascade)
    boxId           Int
    
    // Timestamps
    createdAt       DateTime          @default(now())
    updatedAt       DateTime          @updatedAt
    
    @@unique([boxId, categoryNumber])
}

model InventoryPart {
    id               Int               @id @default(autoincrement())
    partNumber       String
    description      String
    quantityExpected Int               @default(1)
    quantityReceived Int               @default(0)
    category         InventoryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
    categoryId       Int
    
    // Timestamps
    createdAt        DateTime          @default(now())
    updatedAt        DateTime          @updatedAt
    
    @@unique([categoryId, partNumber])
}