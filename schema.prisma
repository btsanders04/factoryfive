datasource db {
    provider = "postgresql"
    // Uses environment variable from .env file
    url      = env("POSTGRES_PRISMA_URL")
}

generator client {
    provider        = "prisma-client-js"
    // For Edge compatibility
    previewFeatures = ["driverAdapters"]
}

model Category {
    id           Int           @id @default(autoincrement())
    name         String
    description  String?
    // Timestamps
    createdAt    DateTime      @default(now())
    updatedAt    DateTime      @updatedAt
    transactions Transaction[]
    Budget       Budget?
    hidden       Boolean       @default(false)

    // Ensure category names are unique per user
    @@unique([name])
}

model Builder {
    id           Int           @id @default(autoincrement())
    name         String
    transactions Transaction[] @relation("Builder")

    // Ensure category names are unique per user
    @@unique([name])
}

model Transaction {
    id          Int      @id @default(autoincrement())
    amount      Float
    date        DateTime
    description String
    notes       String?
    tags        String[]

    // Relations
    category   Category @relation(fields: [categoryId], references: [id])
    categoryId Int

    builder              Builder       @relation("Builder", fields: [builderId], references: [id])
    builderId            Int
    // Self-referential relationship - fixed
    relatedTransactionId Int?
    relatedTransaction   Transaction?  @relation("TransferRelation", fields: [relatedTransactionId], references: [id])
    relatedTo            Transaction[] @relation("TransferRelation")

    Tool Tool[]

    // Timestamps
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Indexes for better query performance
    @@index([categoryId])
    @@index([builderId])
    @@index([date])
}

model Budget {
    id         Int      @id @default(autoincrement())
    amount     Float    @default(0)
    categoryId Int      @unique
    category   Category @relation(fields: [categoryId], references: [id])
}

model Tool {
    id      Int     @id @default(autoincrement())
    name    String
    link    String?
    aquired Boolean @default(false)

    // Relations
    transaction   Transaction? @relation(fields: [transactionId], references: [id])
    transactionId Int?

    // Timestamps
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model WorkHour {
    id    Int      @id @default(autoincrement())
    hours Float    @default(0) @db.DoublePrecision
    date  DateTime @unique @db.Timestamptz

    @@index([date])
}

model Task {
    id             Int          @id @default(autoincrement())
    name           String
    isCompleted    Boolean      @default(false)
    completionDate DateTime?    @db.Timestamptz
    createdAt      DateTime     @default(now())
    updatedAt      DateTime     @updatedAt
    taskSectionId  Int?
    taskSection    TaskSection? @relation(fields: [taskSectionId], references: [id])

    @@index([id])
}

model TaskSection {
    id          Int    @id @default(autoincrement())
    name        String
    description String
    tasks       Task[]
}

model Milestone {
    id               Int      @id @default(autoincrement())
    title            String
    date             DateTime
    description      String
    featuredImage    String?
    additionalImages String[]
    createdAt        DateTime @default(now())
    updatedAt        DateTime @updatedAt
}

model PartsInventory {
    id                   Int       @id @default(autoincrement())
    part                 String
    quantity             Int
    quantityReceived     Int
    status               String
    section              String
    category             String
    notes                String
    estimatedInstallTime String
    installDifficulty    String
    manualPageReference  String
    isOptional           Boolean
    installDate          DateTime?
    dependencies         Int[]
    inspectionNotes      String
    image                String?
    
    // Timestamps
    createdAt            DateTime  @default(now())
    updatedAt            DateTime  @updatedAt
}
